{
  "mcpServers": {
    "dbt-mcp": {
      "command": "dbt-mcp",
      "args": [],
      "env": {
        "DBT_PROJECT_DIR": "/kwwhat",
        "DBT_PROFILES_DIR": "/profiles",
        "DBT_TARGET": "duckdb",
        "DISABLE_REMOTE": "true",
